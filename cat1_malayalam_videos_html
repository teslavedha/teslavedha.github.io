<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Malayalam – Video Classes</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f0f0f0;
        }

        .header {
            background: linear-gradient(90deg, #1e88e5, #42a5f5);
            padding: 18px;
            text-align: center;
            color: white;
            font-size: 24px;
            font-weight: bold;
        }

        .wrap {
            max-width: 820px;
            margin: 20px auto;
            padding: 10px;
        }

        .video-card {
            background: white;
            padding: 18px;
            margin-bottom: 12px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .title {
            font-size: 19px;
            font-weight: bold;
            color: #333;
        }

        .btn {
            margin-top: 12px;
            display: inline-block;
            padding: 10px 18px;
            background: #1e88e5;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-size: 17px;
            transition: 0.2s;
        }

        .btn:hover {
            background: #0d6cc4;
        }
    </style>
</head>
<body>

